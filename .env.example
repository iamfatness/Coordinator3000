# =============================================================================
# Coordinator3000 — environment configuration
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# =============================================================================

# ---- GitHub ----------------------------------------------------------------
# Fine-grained or classic PAT with: repo contents (read/write), pull requests
# (read/write), issues (read/write). Used for clone/push and the REST API.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Shared secret configured on the GitHub webhook (Settings -> Webhooks).
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string
# GitHub REST base URL (change for GitHub Enterprise).
GITHUB_API_URL=https://api.github.com
# Only issues carrying this label trigger an autonomous run.
AI_TASK_LABEL=ai-task

# ---- LLM -------------------------------------------------------------------
# Default provider + model used by every agent. Provider is one of:
#   anthropic  -> Claude   (default; most capable)
#   openai     -> Codex / GPT
#   xai        -> Grok
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=16000
LLM_TIMEOUT=600
LLM_MAX_RETRIES=4

# Per-role overrides — mix AIs across agents. Empty = use the default above.
# Each accepts "model" or "provider:model". Examples:
#   ORCHESTRATOR_MODEL=anthropic:claude-opus-4-8
#   CODER_MODEL=openai:gpt-5-codex
#   REVIEWER_MODEL=xai:grok-4
ORCHESTRATOR_MODEL=
CODER_MODEL=
REVIEWER_MODEL=

# Provider API keys (set the ones you use).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=
XAI_API_KEY=

# ---- Postgres (LangGraph checkpointer) -------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coordinator

# ---- Orchestration ---------------------------------------------------------
# Max coder<->reviewer iterations before we ship what we have.
MAX_ITERATIONS=4
# Where repositories are cloned for each run.
WORKSPACE_ROOT=/tmp/coordinator-workspaces
# Number of concurrent background workers consuming the job queue.
WORKER_CONCURRENCY=2
# Minimal-HITL: when false (default) PRs open ready-for-review automatically.
# When true, PRs open as drafts and the issue is asked for human approval.
REQUIRE_HUMAN_APPROVAL=false

# ---- Sandboxed code execution ----------------------------------------------
# subprocess (workspace-scoped subprocess) or docker (stronger isolation).
SANDBOX_MODE=subprocess
SANDBOX_TIMEOUT=300
SANDBOX_DOCKER_IMAGE=python:3.12-slim

# ---- Git identity for bot commits ------------------------------------------
GIT_AUTHOR_NAME=Coordinator3000
GIT_AUTHOR_EMAIL=bot@coordinator3000.local

# ---- App -------------------------------------------------------------------
LOG_LEVEL=INFO
